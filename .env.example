# SwarMesh Configuration
# Copy to .env and fill in your values

# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_NETWORK=devnet

# Node Configuration
SWARMESH_HOST=0.0.0.0
SWARMESH_PORT=7770
SWARMESH_SECRET=change-this-to-random-secret

# Discovery (how agents find each other)
SWARMESH_BOOTSTRAP_NODES=

# Logging
SWARMESH_LOG_LEVEL=INFO
